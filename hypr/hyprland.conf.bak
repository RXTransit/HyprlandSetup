# Appearance
general {
    gaps_in = 0
    gaps_out = 0
    border_size = 4
    col.active_border = rgb(00bcd4)
    col.inactive_border = rgb(006b7a)
}

decoration {
    rounding = 0
}

# VRR
misc {
    vrr = 2
}

# Monitor config
monitor = HDMI-A-2, 1920x1080@120, 0x0, 1
monitor = HDMI-A-1, 1920x1080@120, 1920x0, 1

# Autostart
exec-once = waybar
exec-once = ~/.azotebg-hyprland
exec-once = discord
exec-once = steam
exec-once = /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1

env = GTK_THEME,Mint-Y-Dark-Blue
env = QT_QPA_PLATFORMTHEME,gtk3
env = TERMINAL,kitty

$mainMod = SUPER
$terminal = kitty
$fileManager = thunar
$menu = rofi -show drun

bind = $mainMod, Q, exec, $terminal
bind = $mainMod, C, killactive,
bind = $mainMod, M, exec, command -v hyprshutdown >/dev/null 2>&1 && hyprshutdown || hyprctl dispatch exit
bind = $mainMod, E, exec, $fileManager
bind = $mainMod, V, togglefloating,
bind = $mainMod, R, exec, $menu
# Pin workspaces to monitors
workspace = 1, monitor:HDMI-A-2, persistent:true
workspace = 2, monitor:HDMI-A-2, persistent:true
workspace = 3, monitor:HDMI-A-2, persistent:true
workspace = 4, monitor:HDMI-A-2, persistent:true
workspace = 5, monitor:HDMI-A-2, persistent:true
workspace = 6, monitor:HDMI-A-1, persistent:true
workspace = 7, monitor:HDMI-A-1, persistent:true
workspace = 8, monitor:HDMI-A-1, persistent:true
workspace = 9, monitor:HDMI-A-1, persistent:true
workspace = 10, monitor:HDMI-A-1, persistent:true

# Workspace switching
bind = $mainMod, 1, workspace, 1
bind = $mainMod, 2, workspace, 2
bind = $mainMod, 3, workspace, 3
bind = $mainMod, 4, workspace, 4
bind = $mainMod, 5, workspace, 5
bind = $mainMod, 6, workspace, 6
bind = $mainMod, 7, workspace, 7
bind = $mainMod, 8, workspace, 8
bind = $mainMod, 9, workspace, 9
bind = $mainMod, 0, workspace, 10

# Move windows to workspaces
bind = $mainMod SHIFT, 1, movetoworkspace, 1
bind = $mainMod SHIFT, 2, movetoworkspace, 2
bind = $mainMod SHIFT, 3, movetoworkspace, 3
bind = $mainMod SHIFT, 4, movetoworkspace, 4
bind = $mainMod SHIFT, 5, movetoworkspace, 5
bind = $mainMod SHIFT, 6, movetoworkspace, 6
bind = $mainMod SHIFT, 7, movetoworkspace, 7
bind = $mainMod SHIFT, 8, movetoworkspace, 8
bind = $mainMod SHIFT, 9, movetoworkspace, 9
bind = $mainMod SHIFT, 0, movetoworkspace, 10


# Move windows in tiling layout
bind = $mainMod, left, movewindow, l
bind = $mainMod, down, movewindow, d
bind = $mainMod, up, movewindow, u
bind = $mainMod, right, movewindow, r

# Screenshots (hyprshot)
bind = , Print, exec, hyprshot -m region
bind = SHIFT, Print, exec, hyprshot -m output
bind = $mainMod, Print, exec, hyprshot -m window

# Window Rules
windowrule = move to cursor, match:class ^(org\.pulseaudio\.pavucontrol)$
# Lock Screen
bind = $mainMod, L, exec, hyprlock
